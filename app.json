{
  "expo": {
    "name": "VoxiraApp",
    "slug": "voxiraapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7F4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voxira.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F7F4"
      },
      "package": "com.voxira.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "htmlTemplate": "./web/index.html"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow VoxiraApp to access your microphone for speech analysis."
        }
      ]
    ]
  }
}